{
  "extends" : "./tsconfig.app.json",
  "compilerOptions" : {
    "module" : "ESNext",
    "moduleResolution" : "bundler",
    "verbatimModuleSyntax" : false,
    "ignoreDeprecations" : "6.0",
    "types" : [
      "jest",
      "node"
    ],
    "esModuleInterop" : true
  },
  "include" : [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude" : []
}

